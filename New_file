/* ===========================================================
   Personal Assistant — Futuristic UI (Flask edition)
   Dark glass · neon accents · monospace data · subtle glow
   No external font dependencies — uses system stacks.
   =========================================================== */

:root {
    --bg-deep:        #050810;
    --bg-base:        #0a0e1a;
    --bg-surface:     #0f1420;
    --accent:         #00f0ff;
    --accent-soft:    rgba(0, 240, 255, 0.15);
    --accent-glow:    rgba(0, 240, 255, 0.35);
    --magenta:        #b794f6;
    --magenta-soft:   rgba(180, 148, 246, 0.15);
    --text:           #e5e7eb;
    --text-muted:     #6b7280;
    --border-glow:    rgba(0, 240, 255, 0.2);
    --success:        #4ade80;
    --warning:        #fbbf24;

    --font-sans:  -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    --font-mono:  ui-monospace, "SF Mono", "Cascadia Mono", "Roboto Mono", Menlo, Monaco, Consolas, monospace;

    --sidebar-w: 320px;
}

* { box-sizing: border-box; }

html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    color: var(--text);
    font-family: var(--font-sans);
    background: var(--bg-base);
}

body {
    background:
        radial-gradient(ellipse 80% 60% at 20% 0%, rgba(0, 240, 255, 0.08) 0%, transparent 50%),
        radial-gradient(ellipse 60% 80% at 80% 100%, rgba(180, 148, 246, 0.08) 0%, transparent 50%),
        linear-gradient(180deg, var(--bg-base) 0%, var(--bg-deep) 100%);
    background-attachment: fixed;
    overflow: hidden;
}

/* Subtle grid overlay */
body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
        linear-gradient(rgba(0, 240, 255, 0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 240, 255, 0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
            mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
}

/* ---------- Layout ---------- */
.layout {
    display: flex;
    height: 100vh;
    position: relative;
    z-index: 1;
}

/* ---------- Sidebar ---------- */
.sidebar {
    width: var(--sidebar-w);
    flex: 0 0 var(--sidebar-w);
    background: rgba(10, 14, 26, 0.7);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border-right: 1px solid var(--border-glow);
    overflow-y: auto;
    overflow-x: hidden;
    transition: width 0.25s ease, flex-basis 0.25s ease;
    position: relative;
}

.sidebar.collapsed {
    width: 0;
    flex-basis: 0;
    border-right: none;
}

.sidebar.collapsed .sidebar-inner,
.sidebar.collapsed .sidebar-toggle {
    display: none;
}

.sidebar-inner {
    padding: 1.25rem 1rem;
}

/* Collapse button inside the sidebar */
.sidebar-toggle {
    position: absolute;
    top: 0.75rem;
    right: 0.5rem;
    width: 24px;
    height: 24px;
    border: 1px solid var(--border-glow);
    background: rgba(15, 20, 32, 0.85);
    color: var(--accent);
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    line-height: 1;
    transition: all 0.2s ease;
    z-index: 2;
}
.sidebar-toggle:hover {
    border-color: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
}

/* Expand button — only visible when sidebar is collapsed */
.sidebar-expand {
    position: fixed;
    top: 1rem;
    left: 0.75rem;
    width: 32px;
    height: 32px;
    border: 1px solid var(--border-glow);
