// =============================================================
//  Personal Assistant — Flask UI client logic
// =============================================================

// ---------- Tiny markdown renderer ----------
// The backend returns markdown (bullets, **bold**, `code`, ~~strike~~, line breaks).
// No external library — small inline implementation, escapes HTML first.

function escapeHtml(s) {
    return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
}

function renderMarkdown(md) {
    let s = escapeHtml(md);

    // Code blocks ```...```
    s = s.replace(/```([\s\S]*?)```/g, (_, code) =>
        `<pre><code>${code}</code></pre>`
    );

    // Inline `code`
    s = s.replace(/`([^`]+)`/g, (_, code) => `<code>${code}</code>`);

    // Bold **text**
    s = s.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");

    // Italic *text* (after bold so we don't catch leftover stars)
    s = s.replace(/\*([^*]+)\*/g, "<em>$1</em>");

    // Strikethrough ~~text~~
    s = s.replace(/~~([^~]+)~~/g, "<del>$1</del>");

    // Bullet lists — group consecutive "- " lines
    const lines = s.split("\n");
    const out = [];
    let inList = false;
    for (const line of lines) {
        const m = line.match(/^- (.*)$/);
        if (m) {
            if (!inList) { out.push("<ul>"); inList = true; }
            out.push(`<li>${m[1]}</li>`);
        } else {
            if (inList) { out.push("</ul>"); inList = false; }
            out.push(line);
        }
    }
    if (inList) out.push("</ul>");
    s = out.join("\n");

    // Paragraphs from double newlines, single newlines as <br>
    s = s
        .split(/\n{2,}/)
        .map(block => {
            if (block.trim().startsWith("<")) return block;          // already HTML
            return "<p>" + block.replace(/\n/g, "<br>") + "</p>";
        })
        .join("\n");

    return s;
}

