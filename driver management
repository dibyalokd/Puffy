@Profile("edge")
@Scope("prototype")
@Bean(destroyMethod = "")
public WebDriver edgeDriver(WebDriverManager edgeDriverManager) {
    // WDM already ran setup — driver path is set
    EdgeOptions options = new EdgeOptions();
    options.addArguments("--no-sandbox", "--disable-dev-shm-usage");
    return new EdgeDriver(options);
}
