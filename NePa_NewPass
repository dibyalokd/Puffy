    client = OpenAI(base_url=LM_STUDIO_BASE_URL, api_key=LM_STUDIO_API_KEY)
    resp = client.chat.completions.create(
        model=CHAT_MODEL,
        messages=[{"role": "user", "content": prompt}],
        temperature=CHAT_TEMPERATURE,
    )
    return resp.choices[0].message.content


def connectEmbedLLM(text: str) -> list:
    """Embed a single text string and return the vector (list of floats)."""
    client = OpenAI(base_url=LM_STUDIO_BASE_URL, api_key=LM_STUDIO_API_KEY)
    resp = client.embeddings.create(model=EMBED_MODEL, input=[text])
    return resp.data[0].embedding


# ============================================================
#  ChromaDB integration
# ============================================================

class LMStudioEmbeddingFunction(EmbeddingFunction):
    """Adapter so ChromaDB calls connectEmbedLLM once per text on add/query."""

    def __call__(self, input):
        # ChromaDB hands us a list of strings — embed each individually.
        return [connectEmbedLLM(text) for text in input]


class TaskStore:
    """Two retrieval modes:
       - get_all(where=...)   — returns ALL matches, no K limit (for 'list' queries)
       - semantic_search(...) — top-K by similarity (for fuzzy lookups)
    """

    def __init__(self, persist_dir=CHROMA_DIR, collection=COLLECTION_NAME):
        self.client = chromadb.PersistentClient(path=persist_dir)
        self.collection = self.client.get_or_create_collection(
            name=collection,
            embedding_function=LMStudioEmbeddingFunction(),
            metadata={"hnsw:space": "cosine"},
        )

    def add_task(self, text: str, status: str = "pending") -> str:
        task_id = str(uuid.uuid4())
        now = datetime.now().isoformat(timespec="seconds")
        self.collection.add(
            ids=[task_id],
            documents=[text],
            metadatas=[{
                "status": status,
                "created_at": now,
                "completed_at": now if status == "completed" else "",
            }],
        )
        return task_id

    def find_pending_match(self, text: str, n_results: int = 3):
        try:
            r = self.collection.query(
                query_texts=[text], n_results=n_results,
                where={"status": "pending"},
            )
        except Exception:
            return None
        if not r["ids"] or not r["ids"][0]:
            return None
        return {
            "id":       r["ids"][0][0],
            "document": r["documents"][0][0],
            "distance": r["distances"][0][0],
            "metadata": r["metadatas"][0][0],
        }

    def mark_completed(self, task_id: str) -> bool:
        existing = self.collection.get(ids=[task_id])
        if not existing["ids"]:
            return False
        meta = existing["metadatas"][0]
        meta["status"] = "completed"
        meta["completed_at"] = datetime.now().isoformat(timespec="seconds")
        self.collection.update(ids=[task_id], metadatas=[meta])
        return True

    def get_all(self, where=None):
        """Return ALL matching tasks — no top-K cap. Use for 'list' queries."""
        return self.collection.get(where=where)

    def semantic_search(self, query: str, where=None, n_results: int = 50):
        return self.collection.query(
            query_texts=[query], n_results=n_results, where=where,
        )


# ============================================================
#  Handlers — return strings (UI-agnostic)
# ============================================================

def handle_todo(text: str, store: TaskStore) -> str:
    task_id = store.add_task(text, "pending")
    return f"📝 Logged as **pending**: {text}  \n`{task_id[:8]}`"


def handle_done(text: str, store: TaskStore) -> str:
    match = store.find_pending_match(text)
    if match and match["distance"] < DONE_MATCH_THRESHOLD:
        store.mark_completed(match["id"])
        return (
            f"✅ Marked complete: {match['document']}  \n"
            f"`{match['id'][:8]}` · matched from \"{text}\" "
            f"(distance {match['distance']:.3f})"
        )
    task_id = store.add_task(text, "completed")
    if match:
        return (
            f"✅ Logged as completed: {text}  \n"
            f"`{task_id[:8]}` · closest pending was \"{match['document']}\" "
            f"(distance {match['distance']:.3f}, above threshold)"
        )
    return f"✅ Logged as completed: {text}  \n`{task_id[:8]}` (no prior todo)"


# Single-string prompt template for the query planner.
# System instructions and user query are folded together with clear delimiters.
_PLANNER_PROMPT_TEMPLATE = """You convert user queries about their personal task list into JSON retrieval plans.
Output ONLY JSON, no prose, no markdown fences.

Schema:
{{
  "query_type": "list" | "search",
  "status": "pending" | "completed" | null,
  "semantic_query": string | null
}}

Rules:
- "list" = return ALL matching tasks. Use for "what are my pending tasks", "show all completed", "list everything about X".
- "search" = top semantically similar. Use for vague lookups like "did I have something about...", "anything on Y?".
- status: filter by status, null if user didn't specify.
- semantic_query: short phrase to embed for ranking/filtering by topic. null if no topic mentioned.

Examples:
"what are my pending tasks" -> {{"query_type":"list","status":"pending","semantic_query":null}}
"show me everything I completed" -> {{"query_type":"list","status":"completed","semantic_query":null}}
"all my pending work tasks" -> {{"query_type":"list","status":"pending","semantic_query":"work"}}
"did I have something about taxes" -> {{"query_type":"search","status":null,"semantic_query":"taxes"}}
"list all my tasks" -> {{"query_type":"list","status":null,"semantic_query":null}}

USER QUERY:
{query}

JSON:"""


def plan_query(query: str) -> dict:
    """Convert a natural-language query into a structured retrieval plan."""
    prompt = _PLANNER_PROMPT_TEMPLATE.format(query=query)
    raw = connectLLM(prompt).strip()

    # Strip markdown fences if model wrapped them
    if raw.startswith("```"):
        raw = raw.strip("`")
        if raw.lower().startswith("json"):
            raw = raw[4:].strip()

    try:
        plan = json.loads(raw)
        plan.setdefault("query_type", "list")
        plan.setdefault("status", None)
        plan.setdefault("semantic_query", None)
        return plan
    except json.JSONDecodeError:
        return {"query_type": "list", "status": None, "semantic_query": None}


def handle_query(query: str, store: TaskStore) -> str:
    plan = plan_query(query)
    where = {"status": plan["status"]} if plan.get("status") else None

    if plan["query_type"] == "list":
        # CRITICAL: get() returns EVERY matching row — no top-K cap.
        result = store.get_all(where=where)
        tasks = list(zip(result["ids"], result["documents"], result["metadatas"]))

        if plan.get("semantic_query") and tasks:
            sem = store.semantic_search(
                plan["semantic_query"], where=where, n_results=len(tasks)
            )
            distances = dict(zip(sem["ids"][0], sem["distances"][0]))
            tasks.sort(key=lambda t: distances.get(t[0], float("inf")))
    else:
        result = store.semantic_search(
            plan["semantic_query"] or query, where=where, n_results=50
        )
        tasks = list(zip(result["ids"][0], result["documents"][0], result["metadatas"][0]))

    if not tasks:
        return "_No matching tasks found._"

    # Format the task list as context for the answering LLM
    lines = []
    for _id, doc, meta in tasks:
        status    = meta.get("status", "?")
        created   = meta.get("created_at", "")[:16].replace("T", " ")
        completed = meta.get("completed_at", "")
        comp_str  = f", completed {completed[:16].replace('T', ' ')}" if completed else ""
        lines.append(f"- [{status}] {doc} (created {created}{comp_str})")
    context = "\n".join(lines)

    answer_prompt = (
        "You are a personal assistant answering questions about the user's tasks. "
        "Use ONLY the task list provided. Be concise. "
        "If the user asked for a list, present EVERY task — do not truncate or summarize. "
        "Use markdown formatting (bullets, bold). Include dates when relevant.\n\n"
        f"My tasks:\n{context}\n\n"
        f"Question: {query}"
    )
    return connectLLM(answer_prompt)


def route(line: str, store: TaskStore) -> str:
    """Dispatch a line to the right handler. Returns a response string."""
    line = line.strip()
    if not line:
        return ""
    lower = line.lower()
    if lower.startswith("todo:"):
        return handle_todo(line[5:].strip(), store)
    elif lower.startswith("done:"):
        return handle_done(line[5:].strip(), store)
    elif lower.startswith("q:"):
        return handle_query(line[2:].strip(), store)
    return handle_query(line, store)


# ============================================================
#  CLI entry point
# ============================================================

def main():
    print("Personal Assistant — LM Studio + ChromaDB")
    print("Prefixes:  todo: <task>   done: <task>   q: <question>   (no prefix → query)")
    print("Type 'exit' to quit.\n")

    store = TaskStore()

    while True:
        try:
            line = input("> ")
        except (EOFError, KeyboardInterrupt):
            print()
            break
        if line.strip().lower() in ("exit", "quit"):
            break
        try:
            response = route(line, store)
            if response:
                print(response, "\n")
        except Exception as e:
            print(f"  ! error: {e}\n")


if __name__ == "__main__":
    main()
